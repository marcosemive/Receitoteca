{
  "name": "receitoteca-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node ./src/index.js",
    "dev": "node --watch ./src/index.js",
    "db:load": "node src/database/load.js",
    "db:drop": "rm src/database/db.sqlite",
    "db:reload": "npm run db:drop && npm run db:load"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "sqlite-async": "^1.2.2"
  }
}
